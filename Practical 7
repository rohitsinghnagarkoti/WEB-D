<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Tribute Page</title>

    <!-- Internal CSS -->
    <style>
        body {
            font-family: Arial;
            margin: 0;
            background-color: #f4f4f4;
        }

        /* Navigation Bar */
        nav {
            background-color: #333;
            padding: 10px;
            text-align: center;
        }
        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }
        nav a:hover {
            color: yellow;
        }

        /* Container Layout */
        .container {
            width: 80%;
            margin: 20px auto;
            background: white;
            padding: 20px;
            border: 2px solid #333;
        }

        /* Image */
        img {
            display: block;
            margin: auto;
            width: 200px;
            border: 3px solid black;
        }

        /* Headings */
        h1, h2 {
            text-align: center;
            color: #333;
        }

        /* Sections */
        section {
            margin-top: 20px;
            padding: 15px;
            border: 1px solid #ccc;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 10px;
            background: #333;
            color: white;
        }
    </style>

</head>
<body>

<!-- Navigation Bar -->
<nav>
    <a href="#about">About</a>
    <a href="#achievements">Achievements</a>
    <a href="#contact">Contact</a>
</nav>

<div class="container">

    <!-- Header -->
    <header>
        <h1>Dr. A.P.J. Abdul Kalam</h1>
        <img src="https://via.placeholder.com/200" alt="Profile Image">
    </header>

    <!-- About Section -->
    <section id="about">
        <h2>About</h2>
        <p>
            Dr. A.P.J. Abdul Kalam was an Indian scientist and the 11th President of India.
            He is known as the "Missile Man of India" for his contribution to space and defense research.
        </p>
    </section>

    <!-- Achievements -->
    <section id="achievements">
        <h2>Achievements</h2>
        <ul>
            <li>Developed India's missile programs</li>
            <li>Key role in Pokhran-II nuclear tests</li>
            <li>Recipient of Bharat Ratna</li>
        </ul>
    </section>

    <!-- Contact -->
    <section id="contact">
        <h2>Contact</h2>
        <p>
            Learn more at 
            <a href="https://en.wikipedia.org/wiki/A._P._J._Abdul_Kalam" target="_blank">
                Wikipedia
            </a>
        </p>
    </section>

</div>

<!-- Footer -->
<footer>
    <p>© Tribute Page</p>
</footer>

</body>
</html>
